DATABASE_URL="postgresql://immo:immo_dev_2026@localhost:5432/immoverwaltung?schema=public"

# JWT Secrets - UNBEDINGT durch starke zufaellige Werte ersetzen!
# Generieren: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET="change-this-to-a-random-secret-min-32-chars"
JWT_REFRESH_SECRET="change-this-to-another-random-secret-min-32-chars"

PORT=3001
NODE_ENV=production

# CORS: Kommagetrennte Liste der erlaubten Frontend-Origins (kein Leerzeichen)
CORS_ORIGINS=https://meine-domain.de

# Upload-Verzeichnis fuer Dokumente
UPLOAD_DIR=./uploads

# DSGVO Art. 32 - Datei-Verschluesselung (empfohlen fuer Produktion)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Seed-Daten beim Start laden (nur fuer Ersteinrichtung, danach auf false!)
SEED_DB=false

# SSL-Zertifikat-Pfad fuer nginx (Let's Encrypt: /etc/letsencrypt/live/DOMAIN)
# Muss fullchain.pem und privkey.pem enthalten
SSL_CERT_PATH=/etc/letsencrypt/live/meine-domain.de

# SMTP (leer lassen = E-Mail-Versand deaktiviert)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@immoverwalt.de
