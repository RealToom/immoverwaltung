# === Immoverwaltung - Docker Deployment ===

# Datenbank-Passwort (unbedingt aendern!)
DB_PASSWORD=ein-sicheres-passwort-hier

# JWT Secrets (unbedingt aendern! Mindestens 32 Zeichen, zufaellig generiert)
JWT_ACCESS_SECRET=zufaelliger-access-secret-min-32-zeichen
JWT_REFRESH_SECRET=zufaelliger-refresh-secret-min-32-zeichen

# Erlaubte Frontend-Origins fuer CORS (Komma-separiert)
CORS_ORIGINS=http://localhost

# Beim ersten Start auf "true" setzen, danach auf "false"
SEED_DB=true

# SMTP fuer E-Mail-Benachrichtigungen (optional, leer = deaktiviert)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@immoverwalt.de
